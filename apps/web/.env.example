# ─────────────────────────────────────────────────────────────────────────────
# Supabase
# Project URL and anon key are safe to expose client-side (guarded by RLS).
# Service role key is server-only — never expose to the browser.
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Stripe
# Secret and webhook keys are server-only.
# Publishable key is safe to expose client-side.
# Price IDs come from your Stripe dashboard (Products → Prices).
# ─────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_MONTHLY_ID=
STRIPE_PRICE_ANNUAL_ID=
STRIPE_PRICE_LIFETIME_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Google AI (Gemini)
# Used by packages/ai for Gemini 1.5 Flash and Pro calls.
# Server-only — never expose client-side.
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# ElevenLabs
# Optional: AI voice synthesis for mentor conversations.
# Without this key, mentors fall back to browser speech synthesis.
# ─────────────────────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# OAuth Connectors
# Strava: https://www.strava.com/settings/api
# Google: https://console.cloud.google.com → Credentials
# Redirect URIs must match exactly what is registered in each provider's dashboard.
# ─────────────────────────────────────────────────────────────────────────────
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Token Encryption
# 256-bit hex key used to AES-encrypt OAuth refresh tokens at rest.
# Generate with: openssl rand -hex 32
# Server-only — never expose client-side.
# ─────────────────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Monitoring
# Sentry: https://sentry.io → Settings → Projects → Client Keys (DSN)
# SENTRY_AUTH_TOKEN is used only by the build to upload source maps.
# PostHog: https://app.posthog.com → Project Settings → Project API Key
# ─────────────────────────────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─────────────────────────────────────────────────────────────────────────────
# App
# NEXT_PUBLIC_APP_URL must not have a trailing slash.
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_APP_NAME=Life Design

# ─────────────────────────────────────────────────────────────────────────────
# Optional: Weather, Search, Maps, Banking, CDN
# ─────────────────────────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_ASSET_CDN=https://assets.lifedesign.app

OPENBANKING_AUTH_URL=https://ob.example.com/authorize
OPENBANKING_TOKEN_URL=https://ob.example.com/token
OPENBANKING_CLIENT_ID=
OPENBANKING_CLIENT_SECRET=
OPENBANKING_API_URL=https://ob.example.com/api
OPENBANKING_FINANCIAL_ID=
