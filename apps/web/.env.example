# ─────────────────────────────────────────────────────────────────────────────
# Supabase
# Project URL and anon key are safe to expose client-side (guarded by RLS).
# Service role key is server-only — never expose to the browser.
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Stripe
# Secret and webhook keys are server-only.
# Publishable key is safe to expose client-side.
# Price IDs come from your Stripe dashboard (Products → Prices).
# ─────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=
STRIPE_PRICE_LIFETIME=

# ─────────────────────────────────────────────────────────────────────────────
# Google AI (Gemini)
# Used by packages/ai for Gemini 1.5 Flash and Pro calls.
# Server-only — never expose client-side.
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_AI_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# OAuth Connectors
# Strava: https://www.strava.com/settings/api
# Google: https://console.cloud.google.com → Credentials
# Redirect URIs must match exactly what is registered in each provider's dashboard.
# ─────────────────────────────────────────────────────────────────────────────
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ─────────────────────────────────────────────────────────────────────────────
# Token Encryption
# 256-bit hex key used to AES-encrypt OAuth refresh tokens at rest.
# Generate with: openssl rand -hex 32
# Server-only — never expose client-side.
# ─────────────────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Monitoring
# Sentry: https://sentry.io → Settings → Projects → Client Keys (DSN)
# SENTRY_AUTH_TOKEN is used only by the build to upload source maps.
# PostHog: https://app.posthog.com → Project Settings → Project API Key
# ─────────────────────────────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─────────────────────────────────────────────────────────────────────────────
# App
# NEXT_PUBLIC_APP_URL must not have a trailing slash.
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_APP_NAME=Life Design
